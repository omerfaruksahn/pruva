"# ─────────────────────────────────────────────\n# PRUVA Backend — Environment Variables\n# cp .env.example .env\n# ─────────────────────────────────────────────\n\n# Server\nPORT=5000\nNODE_ENV=development\n\n# PostgreSQL (backend/db.js için)\nDATABASE_URL=postgresql://user:password@localhost:5432/pruva_db\n\n# JWT\nJWT_SECRET=your_super_secret_jwt_key_min_32_chars\nJWT_EXPIRES_IN=7d\n\n# Email\nRESEND_API_KEY=\n"