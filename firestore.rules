rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardımcı Fonksiyonlar ─────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdminOrOwner(userId) {
      return isAdmin() || isOwner(userId);
    }

    // ── İlanlar (Ads) ─────────────────────────────────────────
    // Okuma: Herkes görebilir (marketplace açık)
    // Oluşturma: Giriş yapmış kullanıcılar
    // Güncelleme/Silme: Sadece ilanı oluşturan kişi (ownerId alanına göre)
    match /ads/{adId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId is string;
      allow update: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bids', 'status', 'operationTimeline', 'documents'])
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerId', 'createdAt', 'id']))
      );
      allow delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;
    }

    // ── Kullanıcılar (Users) ───────────────────────────────────
    // Okuma: Sadece kendi verisini okuyabilir
    //   (Admin panel server-side SDK kullandığından bu kuralları bypass eder)
    // Oluşturma: Sadece kendi UID'si için kayıt oluşturabilir
    // Güncelleme: Sadece kendi verisini güncelleyebilir
    // Silme: İstemci tarafından silme yasak — sadece admin-server.js yapabilir
    match /users/{userId} {
      allow read: if isAdminOrOwner(userId);
      allow create: if isAuthenticated() && userId == request.auth.uid;
      allow update: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'status', 'isAdmin']);
      allow delete: if false;
    }

    // ── Teklifler (Offers) ────────────────────────────────────
    // Okuma: İlanın tarafları (ilan sahibi veya teklif veren)
    // Oluşturma: Giriş yapmış kullanıcılar, kendi UID'leri ile
    // Güncelleme: Sadece teklifi veren
    // Silme: Yasak (sadece admin)
    match /offers/{offerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.carrierId == request.auth.uid
        && request.resource.data.carrierId is string;
      allow update: if isAuthenticated()
        && resource.data.carrierId == request.auth.uid
        && request.resource.data.carrierId == resource.data.carrierId;
      allow delete: if false;
    }

    // ── Bildirimler (Notifications) ───────────────────────────
    // Sadece kendi bildirimleri okunabilir/güncellenebilir
    match /notifications/{notifId} {
      allow read, update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // ── Sohbetler (Chats) ─────────────────────────────────────
    // Sadece sohbete dahil olan kullanıcılar erişebilir
    match /chats/{chatId} {
      allow read, update, delete: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // ── Kurslar (Courses) ─────────────────────────────────────
    // Herkese açık okuma, yazma sadece admin (server-side)
    match /courses/{courseId} {
      allow read: if true;
      allow write: if false; // Sadece admin-server.js
    }

    // ── Whisper Haberleri (Sektörel Haber Botu) ──────────────
    // Herkese açık okuma; yazma sadece GitHub Actions botu (firebase-admin SDK ile,
    // service account kuralları bypass eder, bu yüzden write: false güvenli)
    match /whispers/{whisperId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Kullanıcı İlerlemesi (UserProgress) ──────────────────
    match /userProgress/{progressId} {
      allow read, write: if isAuthenticated()
        && progressId.matches(request.auth.uid + '_.*');
    }

    // ── Varsayılan: Diğer her şey yasak ──────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

